# Public API base (see src/utils/api.js)
# VITE_API_URL=/api

# Optional: public site origin (HTTPS). Used for share links and Razorpay checkout logo
# fallback when VITE_RAZORPAY_CHECKOUT_IMAGE_URL is unset (…/ewarrantify-logo.png).
# VITE_APP_BASE_URL=https://your-domain.com

# Optional: full HTTPS URL to the logo image for Razorpay Standard Checkout (overrides base path).
# Recommended for local dev (localhost cannot be loaded by Razorpay’s iframe).
# VITE_RAZORPAY_CHECKOUT_IMAGE_URL=https://your-domain.com/ewarrantify-logo.png
