// ═══════════════════════════════════════════════════════════════
// Coins System Models
// ═══════════════════════════════════════════════════════════════

// Coin packages that users can purchase
model CoinPackage {
  id          String   @id @default(uuid())
  name        String // "Starter", "Growth", "Business", "Enterprise"
  coins       Int // Base coins in package (e.g., 500)
  bonus_coins Int      @default(0) // Bonus coins (e.g., 100)
  price       Float // Price in INR (e.g., 199.00)
  currency    String   @default("INR")
  description String? // Package description
  is_popular  Boolean  @default(false) // Highlight as popular/recommended
  sort_order  Int      @default(0) // Display order
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  transactions CoinTransaction[]

  @@map("coin_packages")
}

// Provider's coin balance (one per provider)
model ProviderCoinBalance {
  id                  String   @id @default(uuid())
  provider_id         String   @unique
  balance             Int      @default(0) // Current coin balance
  total_earned        Int      @default(0) // Lifetime earned coins
  total_spent         Int      @default(0) // Lifetime spent coins
  profile_bonus_given Boolean  @default(false) // Track if profile completion bonus was given
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // Relations
  provider     Provider          @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  transactions CoinTransaction[]

  @@map("provider_coin_balances")
}

// All coin transactions (credits and debits)
model CoinTransaction {
  id                  String              @id @default(uuid())
  provider_id         String
  balance_id          String // Reference to ProviderCoinBalance
  type                CoinTransactionType // CREDIT or DEBIT
  amount              Int // Positive for credit, positive for debit (absolute value)
  action              CoinAction // What action triggered this transaction
  description         String // Human readable description
  reference_id        String? // Optional: dealer_id, product_id, order_id, etc.
  reference_type      String? // Optional: "dealer", "product", "package", "referral"
  balance_after       Int // Balance after this transaction (for audit)
  package_id          String? // If purchased a package
  razorpay_order_id   String? // Razorpay order ID if payment
  razorpay_payment_id String? // Razorpay payment ID if payment
  created_at          DateTime            @default(now())

  // Relations
  provider Provider            @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  balance  ProviderCoinBalance @relation(fields: [balance_id], references: [id], onDelete: Cascade)
  package  CoinPackage?        @relation(fields: [package_id], references: [id])

  @@index([provider_id])
  @@index([balance_id])
  @@index([action])
  @@index([created_at])
  @@map("coin_transactions")
}

// Referral codes for providers
model ReferralCode {
  id          String   @id @default(uuid())
  provider_id String   @unique
  code        String   @unique // e.g., "JOHN50", auto-generated
  uses_count  Int      @default(0) // How many times this code was used
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  provider  Provider   @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  referrals Referral[] @relation("ReferrerCode")

  @@map("referral_codes")
}

// Track referrals between providers
model Referral {
  id                    String   @id @default(uuid())
  referrer_id           String // Provider who referred
  referred_id           String // Provider who signed up using the code
  referral_code_id      String // The code used
  signup_bonus_given    Boolean  @default(false) // Referrer got bonus for signup
  purchase_bonus_given  Boolean  @default(false) // Referrer got bonus for first purchase
  signup_bonus_amount   Int      @default(0) // Coins given for signup
  purchase_bonus_amount Int      @default(0) // Coins given for first purchase
  created_at            DateTime @default(now())

  // Relations
  referrer      Provider     @relation("ProviderAsReferrer", fields: [referrer_id], references: [id], onDelete: Cascade)
  referred      Provider     @relation("ProviderAsReferred", fields: [referred_id], references: [id], onDelete: Cascade)
  referral_code ReferralCode @relation("ReferrerCode", fields: [referral_code_id], references: [id])

  @@unique([referred_id]) // A provider can only be referred once
  @@index([referrer_id])
  @@map("referrals")
}

// Coin pricing configuration (admin-editable action costs)
model CoinPricing {
  id          String     @id @default(uuid())
  action      CoinAction @unique // Each action has one pricing
  cost        Int // Coins required for this action
  description String // Human readable description
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@map("coin_pricing")
}

// Warranty cost by duration (3mo, 6mo, 12mo) - Super Admin editable
model WarrantyCostConfig {
  id              String   @id @default(uuid())
  duration_months Int      @unique // 3, 6, or 12
  cost            Int // Coins per warranty code
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("warranty_cost_config")
}

