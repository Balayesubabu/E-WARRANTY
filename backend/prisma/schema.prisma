generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Canonical platform roles (seeded; used for JWT + authorize middleware)
enum RoleName {
  SUPER_ADMIN
  BUSINESS_OWNER
  CUSTOMER
}

// Sub-roles under BUSINESS_OWNER (dealer / staff / service center logins)
enum SubRoleName {
  DEALER
  STAFF
  SERVICE_CENTER
}

model User {
  id                               String                    @id @default(uuid())
  first_name                       String?
  last_name                        String?
  email                            String?
  country_code                     String?
  phone_number                     String?                   @unique
  password                         String?
  google_sub                       String?                   @unique
  auth_provider                    String                    @default("password")
  profile_completed                Boolean                   @default(false)
  otp_attempts                     Int                       @default(0)
  otp_request_count                Int                       @default(0)
  otp_last_request                 DateTime?
  api_key                          String?                   @unique
  is_api_key_generated             Boolean                   @default(false)
  is_api_key_active                Boolean                   @default(false)
  date_of_birth                    DateTime?
  profile_image                    String?
  address                          String?
  city                             String?
  state                            String?
  lattitude                        Float?
  longitude                        Float?
  user_type                        String?
  role_id                          String?
  sub_role_id                      String?
  otp                              String?
  is_otp_verified                  Boolean                   @default(false)
  is_phone_verified                Boolean                   @default(false)
  is_email_verified                Boolean                   @default(false)
  otp_expiry                       DateTime?
  is_active                        Boolean                   @default(true)
  is_blocked                       Boolean                   @default(false)
  is_terms_and_conditions_accepted Boolean                   @default(false)
  is_privacy_policy_accepted       Boolean                   @default(false)
  blocked_by_id                    String?
  is_deleted                       Boolean                   @default(false)
  deleted_by_id                    String?
  created_at                       DateTime?
  updated_at                       DateTime?
  FranchiseServiceDeletedBy        FranchiseService[]        @relation("FranchiseServiceDeletedBy")
  FranchiseServicePackageDeletedBy FranchiseServicePackage[] @relation("FranchiseServicePackageDeletedBy")
  ModuleCreatedBy                  Module[]                  @relation("ModuleCreatedBy")
  ModuleDeletedBy                  Module[]                  @relation("ModuleDeletedBy")
  ProviderTax                      ProviderTax[]
  PurchaseInvoice                  PurchaseInvoice[]
  SubModuleCreatedBy               SubModule[]               @relation("SubModuleCreatedBy")
  SubModuleDeletedBy               SubModule[]               @relation("SubModuleDeletedBy")
  UserRole                         UserRole[]
  CustomerVehicle                  ProviderCustomerVehicle[]
  FranchiseDeletedBy               Franchise[]               @relation("FranchiseDeletedBy")
  ProviderCustomers                ProviderCustomers[]
  ProviderSubscription             ProviderSubscription[]    @relation("UserAsProvider")
  Provider                         Provider[]                @relation("UserAsProvider")
  providers                        Provider?                 @relation("UserToProviders")
  canonical_role                   Role?                     @relation("UserCanonicalRole", fields: [role_id], references: [id])
  sub_role                         SubRole?                  @relation(fields: [sub_role_id], references: [id])

  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  name        String
  code        RoleName?  @unique
  description String?
  is_active   Boolean    @default(true)
  is_deleted  Boolean    @default(false)
  UserRole    UserRole[]
  users       User[]     @relation("UserCanonicalRole")
  sub_roles   SubRole[]
}

model SubRole {
  id         String      @id @default(uuid())
  code       SubRoleName @unique
  role_id    String
  role       Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  users      User[]
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  @@map("sub_roles")
}

model UserRole {
  id      String @id @default(uuid())
  user_id String
  role_id String
  role    Role   @relation(fields: [role_id], references: [id])
  user    User   @relation(fields: [user_id], references: [id])
}

model Provider {
  id                                String                              @id @default(uuid())
  user_id                           String                              @unique
  company_name                      String
  company_address                   String
  company_logo                      String?
  company_website                   String?
  company_description               String?
  facebook_url                      String?
  instagram_url                     String?
  youtube_url                       String?
  achivements                       String?
  mode_of_service_offered           String[]
  qr_code_image                     String?
  signature_image                   String?
  cover_image                       String?
  adhaar_card_image                 String?
  pan_card_image                    String?
  post_code                         String?
  gst_number                        String?
  is_kyc_verified                   Boolean                             @default(false)
  invoice_prefix                    String?
  sales_invoice_number              Int?                                @default(0)
  booking_invoice_number            Int?                                @default(0)
  quotation_invoice_number          Int?                                @default(0)
  delivery_challan_invoice_number   Int?                                @default(0)
  proforma_invoice_number           Int?                                @default(0)
  credit_note_invoice_number        Int?                                @default(0)
  sales_return_invoice_number       Int?                                @default(0)
  purchase_invoice_number           Int?                                @default(0)
  purchase_order_invoice_number     Int?                                @default(0)
  purchase_return_invoice_number    Int?                                @default(0)
  debit_note_invoice_number         Int?                                @default(0)
  warranty_serial_number            Int?                                @default(0)
  created_at                        DateTime                            @default(now())
  updated_at                        DateTime                            @updatedAt
  is_active                         Boolean                             @default(true)
  is_deleted                        Boolean                             @default(false)
  deleted_at                        DateTime?
  is_blocked                        Boolean                             @default(false)
  blocked_by_id                     String?
  total_branches                    Int                                 @default(1)
  Appointment                       Appointment[]
  BalanceSheet                      BalanceSheet[]
  Booking                           Booking[]
  BookingCustomerRequirements       BookingCustomerRequirements[]
  BookingParts                      BookingParts[]
  BookingQualityChecks              BookingQualityChecks[]
  BookingServicePackages            BookingServicePackages[]
  BookingServices                   BookingServices[]
  BookingSettings                   BookingSettings[]
  BookingTechnicians                BookingTechnicians[]
  BookingTransactional              BookingTransactional[]
  BookingWorkDetails                BookingWorkDetails[]
  CustomerRequirements              CustomerRequirements[]
  ExpenseCategory                   ExpenseCategory[]
  Expenses                          Expenses[]
  FranchiseInventoryTransaction     FranchiseInventoryTransaction[]
  FranchiseOpenInventoryTransaction FranchiseOpenInventoryTransaction[]
  FranchiseService                  FranchiseService[]
  FranchiseServicePackage           FranchiseServicePackage[]
  Lead                              Lead[]
  ProviderBankDetails               ProviderBankDetails[]
  ProviderDealer                    ProviderDealer[]
  ProviderNotification              ProviderNotification[]
  ProviderProductWarrantyCode       ProviderProductWarrantyCode[]
  ProviderTax                       ProviderTax[]
  ProviderWarrantyCustomer          ProviderWarrantyCustomer[]
  ProviderWarrantyProduct           ProviderWarrantyProduct[]
  ProviderWarrantySetting           ProviderWarrantySetting[]
  PurchaseInvoice                   PurchaseInvoice[]
  SalesInvoice                      SalesInvoice[]
  Staff                             Staff[]                             @relation("ProvidersToStaff")
  StaffRole                         StaffRole[]
  SupportTicketHistory              SupportTicketHistory[]
  TermsAndConditions                TermsAndConditions[]
  Transaction                       Transaction[]
  VehicleBookingOthers              VehicleBookingOthers[]
  Category                          Category[]
  CustomerCategory                  CustomerCategory[]
  Department                        Department[]
  FranchiseInventory                FranchiseInventory[]
  FranchiseOpenInventory            FranchiseOpenInventory[]
  Franchise                         Franchise[]
  InvoiceSettings                   InvoiceSettings[]
  Notification                      Notification[]
  ProviderCustomers                 ProviderCustomers[]
  subscriptions                     ProviderSubscription[]
  blocked_by                        User?                               @relation("UserAsProvider", fields: [blocked_by_id], references: [id])
  user                              User                                @relation("UserToProviders", fields: [user_id], references: [id])
  QuickSettings                     QuickSettings[]
  SupportTicket                     SupportTicket[]                     @relation("ProvidersToSupportTicket")
  ProductMaster                     ProductMaster[]
  WarrantyPolicy                    WarrantyPolicy[]
  WarrantyBatch                     WarrantyBatch[]
  WarrantyClaim                     WarrantyClaim[]
  DealerPurchaseOrder               DealerPurchaseOrder[]
  DealerSalesEntry                  DealerSalesEntry[]
  DealerLedger                      DealerLedger[]
  ServiceCenter                     ServiceCenter[]
  WarrantyTemplate                  WarrantyTemplate[]
  WarrantyRegistration              WarrantyRegistration[]
  // Coins System Relations
  coin_balance                      ProviderCoinBalance?
  coin_transactions                 CoinTransaction[]
  referral_code                     ReferralCode?
  referrals_given                   Referral[]                          @relation("ProviderAsReferrer")
  referred_by                       Referral?                           @relation("ProviderAsReferred")

  @@map("providers")
}

model Staff {
  id                   String                  @id @default(uuid())
  provider_id          String
  franchise_id         String
  name                 String
  email                String
  phone                String
  address              String
  password             String
  is_active            Boolean                 @default(true)
  is_deleted           Boolean                 @default(false)
  deleted_at           DateTime?
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt
  otp                  String?
  otp_expiry           DateTime?
  designation          String?
  role_type            StaffRoleType           @default(Staff)
  department_id        String?
  employee_id          String?
  department           String?
  region               String?
  reports_to_id        String?
  staff_status         StaffStatus             @default(ACTIVE)
  last_login           DateTime?
  force_password_reset Boolean                 @default(true)
  two_factor_enabled   Boolean                 @default(false)
  Booking              Booking[]
  BookingTechnicians   BookingTechnicians[]
  PurchaseInvoice      PurchaseInvoice[]
  SalesInvoice         SalesInvoice[]
  franchise            Franchise               @relation("FranchiseToStaff", fields: [franchise_id], references: [id])
  provider             Provider                @relation("ProvidersToStaff", fields: [provider_id], references: [id])
  reports_to           Staff?                  @relation("StaffReportsTo", fields: [reports_to_id], references: [id])
  subordinates         Staff[]                 @relation("StaffReportsTo")
  StaffRolePermission  StaffRolePermission[]
  Notification         Notification[]
  dealer_assignments   StaffDealerAssignment[]
  WarrantyClaim        WarrantyClaim[]
}

model StaffRole {
  id          String    @id @default(uuid())
  name        String
  provider_id String
  description String?
  is_active   Boolean   @default(true)
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  provider    Provider  @relation(fields: [provider_id], references: [id])
}

model StaffRolePermission {
  id            String              @id @default(uuid())
  staff_id      String
  module_id     String?
  sub_module_id String?
  is_active     Boolean             @default(true)
  is_deleted    Boolean             @default(false)
  deleted_at    DateTime?
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt
  access_type   StaffRoleAccessType
  module        Module?             @relation(fields: [module_id], references: [id], onDelete: Cascade)
  staff         Staff               @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  sub_module    SubModule?          @relation(fields: [sub_module_id], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id                   String                 @id @default(uuid())
  staff_id             String?
  provider_id          String
  franchise_id         String
  title                String
  description          String
  image1               String?
  image2               String?
  image3               String?
  image4               String?
  status               supportTicketType
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt
  SupportTicketHistory SupportTicketHistory[]
  franchise            Franchise              @relation("FranchiseToSupportTicket", fields: [franchise_id], references: [id])
  provider             Provider               @relation("ProvidersToSupportTicket", fields: [provider_id], references: [id])

  @@map("supportTicket")
}

model SupportTicketHistory {
  id               String        @id @default(uuid())
  supportTicket_id String
  message          String
  staff_id         String?
  provider_id      String        @default("23df98bb-51a0-4f1d-b358-794c02f5d0e5")
  franchise_id     String        @default("66ff36f0-5fda-4411-8e2e-990343b1ea74")
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  franchise        Franchise     @relation(fields: [franchise_id], references: [id])
  provider         Provider      @relation(fields: [provider_id], references: [id])
  supportTicket    SupportTicket @relation(fields: [supportTicket_id], references: [id], onDelete: Cascade)

  @@map("SupportTicketHistory")
}

model ProviderBankDetails {
  id                          String            @id @default(uuid())
  provider_id                 String
  bank_name                   String
  bank_account_number         String
  bank_ifsc_code              String
  bank_branch_name            String?
  bank_account_holder_name    String?
  bank_account_holder_address String?
  bank_account_holder_email   String?
  bank_account_holder_phone   String?
  is_primary                  Boolean           @default(false)
  is_active                   Boolean           @default(true)
  is_deleted                  Boolean           @default(false)
  deleted_at                  DateTime?
  created_at                  DateTime          @default(now())
  updated_at                  DateTime          @updatedAt
  provider                    Provider          @relation(fields: [provider_id], references: [id])
  PurchaseInvoice             PurchaseInvoice[]
  SalesInvoice                SalesInvoice[]
}

model ProviderSubscription {
  id                   String           @id @default(uuid())
  provider_id          String
  subscription_plan_id String
  start_date           DateTime
  end_date             DateTime
  amount_paid          Float
  is_active            Boolean          @default(true)
  is_cancelled         Boolean          @default(false)
  is_base_plan_active  Boolean          @default(false)
  cancelled_at         DateTime?
  cancelled_by_id      String?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  userId               String?
  cancelled_by         User?            @relation("UserAsProvider", fields: [cancelled_by_id], references: [id])
  provider             Provider         @relation(fields: [provider_id], references: [id])
  subscription_plan    SubscriptionPlan @relation(fields: [subscription_plan_id], references: [id])

  @@map("provider_subscriptions")
}

model Module {
  id                  String                   @id @default(uuid())
  name                String
  description         String
  is_active           Boolean                  @default(true)
  is_deleted          Boolean                  @default(false)
  deleted_at          DateTime?
  deleted_by_id       String?
  created_at          DateTime                 @default(now())
  created_by_id       String?
  updated_at          DateTime                 @updatedAt
  created_by          User?                    @relation("ModuleCreatedBy", fields: [created_by_id], references: [id])
  deleted_by          User?                    @relation("ModuleDeletedBy", fields: [deleted_by_id], references: [id])
  StaffRolePermission StaffRolePermission[]
  SubModule           SubModule[]
  SubscriptionPlans   SubscriptionPlanModule[]
}

model SubModule {
  id                  String                @id @default(uuid())
  module_id           String
  name                String
  description         String
  is_active           Boolean               @default(true)
  is_deleted          Boolean               @default(false)
  deleted_at          DateTime?
  deleted_by_id       String?
  created_at          DateTime              @default(now())
  created_by_id       String?
  updated_at          DateTime              @updatedAt
  StaffRolePermission StaffRolePermission[]
  created_by          User?                 @relation("SubModuleCreatedBy", fields: [created_by_id], references: [id])
  deleted_by          User?                 @relation("SubModuleDeletedBy", fields: [deleted_by_id], references: [id])
  module              Module                @relation(fields: [module_id], references: [id])
}

model SubscriptionPlan {
  id           String                   @id @default(uuid())
  name         String
  description  String
  price        Float
  is_active    Boolean                  @default(true)
  is_deleted   Boolean                  @default(false)
  is_base_plan Boolean                  @default(false)
  created_at   DateTime                 @default(now())
  updated_at   DateTime                 @updatedAt
  providers    ProviderSubscription[]
  modules      SubscriptionPlanModule[]
}

model SubscriptionPlanModule {
  id                   String           @id @default(uuid())
  subscription_plan_id String
  module_id            String
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  module               Module           @relation(fields: [module_id], references: [id])
  subscription_plan    SubscriptionPlan @relation(fields: [subscription_plan_id], references: [id])

  @@unique([subscription_plan_id, module_id])
  @@map("subscription_plan_modules")
}

model Franchise {
  id                                String                              @id @default(uuid())
  provider_id                       String
  name                              String?
  address                           String?
  city                              String?
  state                             String?
  country                           String?
  pin_code                          String?
  email                             String?
  phone_number                      String?
  latitude                          Float?
  longitude                         Float?
  created_at                        DateTime                            @default(now())
  updated_at                        DateTime?
  is_active                         Boolean                             @default(true)
  is_deleted                        Boolean                             @default(false)
  deleted_at                        DateTime?
  deleted_by_id                     String?
  created_by_id                     String?
  userId                            String?
  providerId                        String?
  created_by                        String?
  updated_by                        String?
  Appointment                       Appointment[]
  BalanceSheet                      BalanceSheet[]
  Booking                           Booking[]
  BookingCustomerRequirements       BookingCustomerRequirements[]
  BookingParts                      BookingParts[]
  BookingQualityChecks              BookingQualityChecks[]
  BookingServicePackages            BookingServicePackages[]
  BookingServices                   BookingServices[]
  BookingSettings                   BookingSettings[]
  BookingTechnicians                BookingTechnicians[]
  BookingTransactional              BookingTransactional[]
  BookingWorkDetails                BookingWorkDetails[]
  CustomerRequirements              CustomerRequirements[]
  ExpenseCategory                   ExpenseCategory[]
  Expenses                          Expenses[]
  FranchiseInventoryTransaction     FranchiseInventoryTransaction[]
  FranchiseOpenInventoryTransaction FranchiseOpenInventoryTransaction[]
  FranchiseService                  FranchiseService[]
  FranchiseServicePackage           FranchiseServicePackage[]
  Lead                              Lead[]
  PurchaseInvoice                   PurchaseInvoice[]
  SalesInvoice                      SalesInvoice[]
  Staff                             Staff[]                             @relation("FranchiseToStaff")
  SupportTicketHistory              SupportTicketHistory[]
  VehicleBookingOthers              VehicleBookingOthers[]
  Department                        Department[]
  FranchiseInventory                FranchiseInventory[]
  FranchiseOpenInventory            FranchiseOpenInventory[]
  deleted_by                        User?                               @relation("FranchiseDeletedBy", fields: [deleted_by_id], references: [id])
  Provider                          Provider                            @relation(fields: [provider_id], references: [id])
  Notification                      Notification[]
  QuickSettings                     QuickSettings[]
  SupportTicket                     SupportTicket[]                     @relation("FranchiseToSupportTicket")
  WarrantyClaim                     WarrantyClaim[]

  @@map("franchises")
}

model Category {
  id                   String    @id @default(uuid())
  category_name        String
  category_description String?
  provider_id          String
  is_active            Boolean   @default(true)
  is_deleted           Boolean   @default(false)
  deleted_at           DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  provider             Provider  @relation(fields: [provider_id], references: [id])

  @@map("categories")
}

model Department {
  id              String    @id @default(uuid())
  department_name String
  provider_id     String
  franchise_id    String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  franchise       Franchise @relation(fields: [franchise_id], references: [id])
  provider        Provider  @relation(fields: [provider_id], references: [id])

  @@map("department")
}

model FranchiseInventory {
  id                            String                          @id @default(uuid())
  franchise_id                  String
  provider_id                   String
  staff_id                      String?
  product_id                    String?
  product_name                  String
  product_hsn_code              String?
  product_item_code             String
  product_custom_code           String?
  product_image                 String[]
  product_description           String?
  product_purchase_price        Float?
  product_selling_price         Float?
  product_sales_price_type      String?
  product_purchase_price_type   String?
  product_selling_price_input   Int?                            @default(0)
  product_quantity              Int?                            @default(0)
  open_inventory_quantity       Int?                            @default(0)
  open_inventory                Boolean                         @default(false)
  product_measurement           Int?                            @default(0)
  product_measuring_unit        String?
  secondary_measuring_unit      String?
  convertion_rate               Int?                            @default(0)
  product_gst_percentage        Float?
  product_gst_amount            Float?
  product_original_price        Float?
  product_total_price           Float?
  product_status                String?
  product_is_active             Boolean?                        @default(true)
  product_is_deleted            Boolean?                        @default(false)
  product_low_stock_level       Int?
  product_reorder_level         Int?
  category_id                   String?
  created_at                    DateTime                        @default(now())
  updated_at                    DateTime                        @updatedAt
  created_by                    String?
  updated_by                    String?
  FranchiseInventoryTransaction FranchiseInventoryTransaction[]
  ProviderProductWarrantyCode   ProviderProductWarrantyCode[]
  ProviderWarrantyCustomer      ProviderWarrantyCustomer[]
  PurchasePart                  PurchasePart[]
  SalesPart                     SalesPart[]
  franchise                     Franchise                       @relation(fields: [franchise_id], references: [id])
  provider                      Provider                        @relation(fields: [provider_id], references: [id])
  FranchiseOpenInventory        FranchiseOpenInventory[]

  @@map("franchise_inventories")
}

model FranchiseOpenInventory {
  id                                String                              @id @default(uuid())
  franchise_inventory_id            String
  franchise_id                      String
  provider_id                       String
  staff_id                          String?
  product_id                        String?
  product_name                      String
  product_hsn_code                  String?
  product_item_code                 String
  open_inventory_item_code          String
  product_custom_code               String?
  product_image                     String[]
  product_description               String?
  product_purchase_price            Float?
  product_selling_price             Float?
  product_quantity                  Int
  product_measurement               Int?                                @default(0)
  product_measuring_unit            String?
  secondary_measuring_unit          String?
  convertion_rate                   Int?                                @default(0)
  product_gst_percentage            Float?
  product_gst_amount                Float?
  product_original_price            Float?
  product_total_price               Float?
  product_status                    String?
  product_is_active                 Boolean?                            @default(true)
  product_is_deleted                Boolean?                            @default(false)
  category_id                       String?
  created_at                        DateTime                            @default(now())
  updated_at                        DateTime?
  created_by                        String?
  updated_by                        String?
  BookingParts                      BookingParts[]
  FranchiseOpenInventoryTransaction FranchiseOpenInventoryTransaction[]
  franchise                         Franchise                           @relation(fields: [franchise_id], references: [id])
  franchise_inventories             FranchiseInventory                  @relation(fields: [franchise_inventory_id], references: [id])
  provider                          Provider                            @relation(fields: [provider_id], references: [id])

  @@map("franchise_open_inventories")
}

model FranchiseService {
  id                          String                        @id @default(uuid())
  franchise_id                String
  provider_id                 String
  staff_id                    String?
  service_id                  String?
  service_name                String
  service_sac_code            String?
  service_number              String?
  service_short_description   String?
  service_icon                String?
  service_is_featured         Boolean                       @default(false)
  service_type                String?
  service_description         String?
  service_is_active           Boolean                       @default(true)
  service_slug                String?
  service_price               Float?
  service_gst_percentage      Float?
  service_gst_amount          Float?
  service_total_price         Float?
  service_is_deleted          Boolean                       @default(false)
  products_list               Json?
  check_list                  Json?
  duration                    Int?
  service_deleted_at          DateTime?
  service_deleted_by_id       String?
  created_at                  DateTime                      @default(now())
  created_by_id               String?
  updated_at                  DateTime?
  created_by                  String?
  updated_by                  String?
  Appointment                 Appointment[]
  BookingServices             BookingServices[]
  franchise                   Franchise                     @relation(fields: [franchise_id], references: [id])
  provider                    Provider                      @relation(fields: [provider_id], references: [id])
  service_deleted_by          User?                         @relation("FranchiseServiceDeletedBy", fields: [service_deleted_by_id], references: [id])
  Lead                        Lead[]
  ProviderProductWarrantyCode ProviderProductWarrantyCode[]
  ProviderWarrantyCustomer    ProviderWarrantyCustomer[]
  PurchaseService             PurchaseService[]
  SalesService                SalesService[]
  packages                    FranchiseServicePackage[]     @relation("PackageServices")
}

model FranchiseServicePackage {
  id                     String                   @id @default(uuid())
  provider_id            String
  franchise_id           String
  staff_id               String?
  package_name           String
  package_description    String?
  package_price          Float
  duration               Int?
  package_is_active      Boolean                  @default(true)
  package_is_deleted     Boolean                  @default(false)
  deleted_at             DateTime?
  deleted_by_id          String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime?
