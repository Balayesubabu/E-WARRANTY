// Coins System Enums
// ═══════════════════════════════════════════════════════════════

enum CoinTransactionType {
  CREDIT // Coins added to balance
  DEBIT // Coins deducted from balance
}

enum CoinAction {
  // Earning Actions (CREDIT)
  WELCOME_BONUS // New owner signup bonus
  PROFILE_COMPLETE // Owner completes profile setup
  REFERRAL_SIGNUP // Someone signs up using your referral code
  REFERRAL_PURCHASE // Referred user makes first purchase
  PURCHASE_PACKAGE // Bought a coin package
  PURCHASE_CUSTOM // Wallet top-up (custom amount, 1 rupee = 1 coin)
  ADMIN_CREDIT // Admin manually added coins
  PROMOTIONAL // Promotional/bonus coins

  // Spending Actions (DEBIT)
  CREATE_DEALER // Created a new dealer
  ADD_PRODUCT // Added a new product
  GENERATE_WARRANTY_CODE // Generated warranty codes (per code)
  GENERATE_QR_BATCH // Generated QR code batch
  SEND_SMS // Sent SMS notification
  SEND_EMAIL // Sent email notification
  DOWNLOAD_REPORT // Downloaded a report
  CREATE_STAFF // Created a new staff member
  ADMIN_DEBIT // Admin manually deducted coins
}

// Super Admin platform activity audit log
model SuperAdminActivityLog {
  id             String   @id @default(uuid())
  super_admin_id String
  action         String // provider_blocked, coins_added, dealer_activated, etc.
  entity_type    String // provider, dealer, staff, service_center, coin_pricing
  entity_id      String?
  provider_id    String?
  target_name    String? // Human-readable: provider/dealer/staff/sc name
  details        Json? // { amount, reason, old_values, new_values }
  ip_address     String?
  created_at     DateTime @default(now())

  @@index([super_admin_id])
  @@index([action])
  @@index([entity_type])
  @@index([provider_id])
  @@index([created_at])
  @@map("super_admin_activity_logs")
}

// Platform-wide activity log (Super Admin, Provider, Dealer, Staff, Customer)
model PlatformActivityLog {
  id                 String   @id @default(uuid())
  actor_role         String // super_admin, provider, dealer, staff, customer
  actor_id           String
  actor_name         String?
  action             String // e.g. provider_blocked, dealer_created, warranty_registered
  target_entity_type String? // provider, dealer, staff, warranty, claim, etc.
  target_entity_id   String?
  target_name        String?
  provider_id        String?
  details            Json?
  created_at         DateTime @default(now())

  @@index([actor_role])
  @@index([action])
  @@index([target_entity_type])
  @@index([provider_id])
  @@index([created_at])
  @@map("platform_activity_logs")
}
