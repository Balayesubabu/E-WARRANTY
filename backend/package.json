{
  "name": "sharyo-api",
  "version": "1.0.0",
  "prisma": {
    "seed": "node prisma/seed/index.js"
  },
  "description": "Sharyo API Server with JWT and API Key authentication",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "git:demo": "node -e \"console.log('backend git demo script OK')\"",
    "prisma:reset": "npx prisma migrate reset --force",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "cross-env NODE_ENV=development npx prisma migrate dev",
    "prisma:seed": "cross-env NODE_ENV=development node prisma/seed/index.js",
    "prisma:seed:super-admin": "cross-env NODE_ENV=development node prisma/seed/super-admin-seeder/run-standalone.js",
    "prisma:migrate:prod": "cross-env NODE_ENV=production npx prisma migrate deploy",
    "prisma:deploy": "npx prisma migrate deploy && npx prisma generate",
    "prisma:local-bootstrap": "npx prisma db execute --schema prisma/schema.prisma --file prisma/reset-public-schema.sql && npx prisma migrate deploy && npx prisma generate && npm run prisma:seed",
    "prisma:format": "npx prisma format",
    "prisma:studio": "npx prisma studio",
    "prisma:dev": "cross-env NODE_ENV=development npx prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.899.0",
    "@prisma/adapter-pg": "^6.7.0",
    "@prisma/client": "^6.7.0",
    "aws-sdk": "^2.1692.0",
    "pg": "^8.18.0",
    "axios": "^1.9.0",
    "base64-stream": "^1.0.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "csv-parse": "^5.6.0",
    "dayjs": "^1.11.18",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.5",
    "node-cron": "^4.0.7",
    "nodemailer": "^7.0.3",
    "number-to-words": "^1.2.4",
    "pdfkit": "^0.17.1",
    "puppeteer": "^24.22.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "to-words": "^4.7.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "cross-env": "^10.0.0",
    "nodemon": "^3.0.3",
    "prisma": "^6.7.0",
    "rimraf": "^6.0.1"
  }
}
